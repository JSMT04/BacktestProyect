# === FUENTES DE DATOS ===
ALPHA_VANTAGE_KEY=your_key_here
BINANCE_API_KEY=your_key_here       # Opcional, CCXT funciona sin key para históricos
BINANCE_API_SECRET=your_secret_here # Opcional

# === BASE DE DATOS ===
DATABASE_URL=sqlite+aiosqlite:///./data/backtestpro.db

# === SERVIDOR ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === SEGURIDAD ===
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
AUTH_ENABLED=false
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 días

# === CACHE ===
CACHE_DIR=./data/cache
CACHE_MAX_AGE_HOURS=24
MAX_CACHE_SIZE_GB=10

# === BACKTESTING ===
MAX_BACKTEST_WORKERS=4
MAX_CANDLES_LIMIT=500000
